{
  "schemaVersion": 4,
  "sourcePolicy": "cloud-only",
  "allowedProviders": [
    "gcs"
  ],
  "queryOrder": [
    "prepared-web-data",
    "raw-cmip6"
  ],
  "routes": {
    "prepared-web-data": {
      "provider": "gcs",
      "role": "primary"
    },
    "raw-cmip6": {
      "provider": "gcs",
      "role": "coverage-fallback"
    }
  },
  "localFilesystemSourceAllowed": false,
  "browserStorageLocatorExposure": false,
  "delivery": {
    "frontend": "github-pages",
    "queryApi": "public-read-only-cloud-run",
    "preparedData": "public-object-read-only-gcs",
    "anonymousWriteAllowed": false
  },
  "deploymentAttestation": {
    "attestationVersion": 3,
    "requiredFields": [
      "allowedProviders",
      "attestationVersion",
      "attributionReady",
      "backendCommitSha",
      "datasetUpdatedAt",
      "datasetVersion",
      "frontendCommitSha",
      "gateway",
      "internalPathExposure",
      "preparedData",
      "publicSafe",
      "queryOrder",
      "rawData",
      "verifiedAtUtc"
    ],
    "internalPathExposureAllowed": false
  }
}
